{
  "$schema": "https://transcend.tools/schema/skill/v1.json",
  "name": "git_remote",
  "version": "1.0.0",
  "stability": "stable",
  "category": "version_control",
  "description": "Manages and inspects Git remotes with rich metadata. Supports listing remotes with fetch/push URLs, adding, removing, renaming, setting URLs, showing detailed remote info including HEAD branch and tracked branches with stale flags, pruning stale refs, and getting URLs.",
  "requires": {
    "primary": {
      "command": "git",
      "min_version": "2.30.0"
    },
    "dependencies": [
      {
        "type": "runtime",
        "name": "node",
        "min_version": "18.0.0"
      },
      {
        "type": "template_engine",
        "name": "nunjucks",
        "note": "Nunjucks template engine is required for argument rendering."
      }
    ],
    "permissions": [
      "filesystem.read"
    ]
  },
  "inputs": {
    "path": {
      "type": "string",
      "default": ".",
      "description": "Path to the Git repository or a subdirectory within it.",
      "validation": {
        "must_exist": true
      }
    },
    "action": {
      "type": "string",
      "enum": ["list", "add", "remove", "rename", "set_url", "show", "prune", "get_url"],
      "default": "list",
      "description": "Remote action to perform. 'list' returns remote metadata. 'add', 'remove', 'rename', 'set_url', and 'prune' mutate the repository. 'show' and 'get_url' inspect a specific remote."
    },
    "remote_name": {
      "type": "string",
      "description": "Name of the remote to operate on. Required for add, remove, rename, set_url, show, prune, and get_url."
    },
    "url": {
      "type": "string",
      "description": "URL for the remote. Required for add and set_url actions."
    },
    "new_name": {
      "type": "string",
      "description": "New name for the remote when action is 'rename'."
    },
    "branch": {
      "type": "string",
      "description": "Branch to track when adding a remote. Adds -t <branch> to git remote add."
    },
    "push_url": {
      "type": "boolean",
      "default": false,
      "description": "For set_url, set the push URL instead of fetch URL. For get_url, retrieve the push URL instead of fetch URL."
    },
    "all": {
      "type": "boolean",
      "default": false,
      "description": "For get_url, return all URLs for the remote. Adds --all flag."
    }
  },
  "outputs": {
    "success": {
      "type": "object",
      "required": [
        "status",
        "remotes",
        "total_remotes",
        "warnings"
      ],
      "properties": {
        "status": {
          "type": "string",
          "const": "ok"
        },
        "remotes": {
          "type": "array",
          "description": "Array of remote objects with rich metadata.",
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Remote name."
              },
              "fetch_url": {
                "type": ["string", "null"],
                "description": "Fetch URL for the remote. Null if not available."
              },
              "push_url": {
                "type": ["string", "null"],
                "description": "Push URL for the remote. Null if not available."
              },
              "head_branch": {
                "type": ["string", "null"],
                "description": "HEAD branch reported by the remote. Present only for show action."
              },
              "tracked_branches": {
                "type": "array",
                "description": "Remote-tracking branches with stale flags. Present only for show action.",
                "items": {
                  "type": "object",
                  "required": [
                    "name",
                    "stale",
                    "tracked"
                  ],
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "stale": {
                      "type": "boolean",
                      "description": "True if the remote branch is stale and can be pruned."
                    },
                    "tracked": {
                      "type": "boolean",
                      "description": "True if the remote branch is actively tracked."
                    },
                    "new": {
                      "type": "boolean",
                      "description": "True if the remote branch is new (next fetch will store it)."
                    }
                  }
                }
              }
            }
          }
        },
        "total_remotes": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of remotes in the remotes array."
        },
        "truncated": {
          "type": "boolean",
          "description": "True if the result was truncated. Always false for git_remote."
        },
        "added": {
          "type": "string",
          "description": "Name of the remote added. Present only for add action."
        },
        "removed": {
          "type": "string",
          "description": "Name of the remote removed. Present only for remove action."
        },
        "renamed": {
          "type": "boolean",
          "description": "True if rename succeeded. Present only for rename action."
        },
        "renamed_from": {
          "type": "string",
          "description": "Original remote name. Present only for rename action."
        },
        "renamed_to": {
          "type": "string",
          "description": "New remote name. Present only for rename action."
        },
        "url_set": {
          "type": "boolean",
          "description": "True if set_url succeeded. Present only for set_url action."
        },
        "pruned": {
          "type": "boolean",
          "description": "True if prune succeeded. Present only for prune action."
        },
        "execution_ms": {
          "type": "integer",
          "description": "Wall-clock execution time in milliseconds."
        },
        "used_fallback": {
          "type": "boolean"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Non-fatal advisories emitted during execution."
        }
      }
    },
    "error": {
      "type": "object",
      "required": [
        "status",
        "error_type",
        "message"
      ],
      "properties": {
        "status": {
          "type": "string",
          "const": "error"
        },
        "error_type": {
          "type": "string",
          "enum": [
            "command_not_found",
            "not_a_git_repo",
            "invalid_argument",
            "remote_not_found",
            "timeout",
            "unknown"
          ]
        },
        "message": {
          "type": "string",
          "description": "Human-readable description of the failure."
        },
        "exit_code": {
          "type": ["integer", "null"]
        },
        "stderr": {
          "type": "string"
        },
        "used_fallback": {
          "type": "boolean"
        }
      }
    }
  },
  "execution": {
    "engine": "subprocess",
    "template_engine": "nunjucks",
    "timeout_ms": 15000,
    "command": "git",
    "args": [
      "-C",
      "{{ path }}",
      "remote",
      "{% if action == 'list' %}-v{% endif %}",
      "{% if action == 'add' %}add{% endif %}",
      "{% if action == 'add' and branch %}-t{% endif %}",
      "{% if action == 'add' and branch %}{{ branch }}{% endif %}",
      "{% if action == 'add' %}{{ remote_name }}{% endif %}",
      "{% if action == 'add' %}{{ url }}{% endif %}",
      "{% if action == 'remove' %}remove{% endif %}",
      "{% if action == 'remove' %}{{ remote_name }}{% endif %}",
      "{% if action == 'rename' %}rename{% endif %}",
      "{% if action == 'rename' %}{{ remote_name }}{% endif %}",
      "{% if action == 'rename' %}{{ new_name }}{% endif %}",
      "{% if action == 'set_url' %}set-url{% endif %}",
      "{% if action == 'set_url' and push_url %}--push{% endif %}",
      "{% if action == 'set_url' %}{{ remote_name }}{% endif %}",
      "{% if action == 'set_url' %}{{ url }}{% endif %}",
      "{% if action == 'show' %}show{% endif %}",
      "{% if action == 'show' %}{{ remote_name }}{% endif %}",
      "{% if action == 'prune' %}prune{% endif %}",
      "{% if action == 'prune' %}{{ remote_name }}{% endif %}",
      "{% if action == 'get_url' %}get-url{% endif %}",
      "{% if action == 'get_url' and all %}--all{% endif %}",
      "{% if action == 'get_url' and push_url %}--push{% endif %}",
      "{% if action == 'get_url' %}{{ remote_name }}{% endif %}"
    ],
    "exit_code_map": {
      "0": "success",
      "1": "error",
      "128": "fatal_git_error"
    }
  },
  "normalization": {
    "input_format": "plaintext",
    "pipeline": [
      {
        "step": "parse_git_remote",
        "description": "Parse git remote -v output for fetch/push URLs, git remote show for head_branch and tracked branch stale flags, and git remote get-url for URL retrieval."
      },
      {
        "step": "assemble_output",
        "description": "Build final envelope with remotes array, total_remotes, and action-specific fields (added, removed, renamed, url_set, pruned)."
      }
    ]
  },
  "resilience": {
    "retry": {
      "on_errors": [
        "ETIMEDOUT"
      ],
      "max_retries": 1,
      "backoff_ms": 500
    },
    "fallback": {
      "condition": "command_not_found",
      "command": "git",
      "args": [
        "-C",
        "{{ path }}",
        "remote"
      ],
      "normalization": "git_remote_short",
      "output_gaps": [
        "fetch_url and push_url unavailable",
        "head_branch unavailable",
        "tracked branches unavailable"
      ]
    }
  },
  "chains": {
    "produces": {
      "types": [
        "remote_name",
        "url"
      ],
      "schema_ref": "https://transcend.tools/schema/types/git_remote/v1.json"
    },
    "compatible_downstream": [
      {
        "skill": "git_branch",
        "via": [
          "path"
        ],
        "description": "List branches after inspecting or modifying remotes."
      },
      {
        "skill": "git_log",
        "via": [
          "path"
        ],
        "description": "Query commit history on remote tracking branches."
      },
      {
        "skill": "git_status",
        "via": [
          "path"
        ],
        "description": "Check working tree status after remote operations."
      }
    ],
    "compatible_upstream": [
      {
        "skill": "directory_list",
        "via": [
          "path"
        ],
        "description": "Receive a repository path from directory_list to scope the remote query."
      }
    ]
  },
  "metadata": {
    "platforms": [
      "linux",
      "macos",
      "windows",
      "wsl"
    ],
    "tags": [
      "git",
      "version-control",
      "remote",
      "repository"
    ],
    "performance": {
      "typical_execution_ms": 50,
      "worst_case_execution_ms": 15000,
      "output_scale": "O(remotes)",
      "token_pressure": "low"
    }
  }
}
